{
    "containerDefinitions": [
        {
            "name": "api-gateway",
            "image": "697863031884.dkr.ecr.eu-west-1.amazonaws.com/versapath/api-gateway:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp",
                    "name": "api-gateway"
                }
            ],
            "essential": true,
            "environment": [
                {
                    "name": "SERVER_PORT",
                    "value": "8080"
                },
                {
                    "name": "CONFIG_SERVER_URL",
                    "value": "http://config-server:8888"
                },
                {
                    "name": "SPRING_APPLICATION_NAME",
                    "value": "api-gateway"
                },
                {
                    "name": "SPRING_PROFILES_ACTIVE",
                    "value": "docker"
                },
                {
                    "name": "EUREKA_CLIENT_URL",
                    "value": "http://service-discovery:8761/eureka"
                },
                {
                    "name": "REACT_DEV_SERVER",
                    "value": "http://localhost:3000"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/versapath/api-gateway",
                    "awslogs-region": "eu-west-1",
                    "awslogs-stream-prefix": "api-gateway"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "wget --no-verbose --tries=1 --spider http://localhost:8080/actuator/health || curl -f http://localhost:8080/actuator/health || exit 1"
                ],
                "interval": 60,
                "timeout": 10,
                "retries": 3,
                "startPeriod": 120
            },
            "systemControls": []
        }
    ],
    "family": "versapath-api-gateway",
    "taskRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-role",
    "executionRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-execution-role",
    "networkMode": "awsvpc",
    "volumes": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024"
}
